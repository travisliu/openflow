{
  "name": "openflow",
  "version": "0.1.0",
  "description": "Local-first workflow CLI for orchestrating coding-agent CLIs.",
  "type": "module",
  "private": true,
  "bin": {
    "openflow": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "postbuild": "node scripts/fix-bin-permissions.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run clean && npm run build",
    "pack:local": "npm pack",
    "publish:dry-run": "npm publish --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "20",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "commander": "^15.0.0",
    "yaml": "^2.9.0"
  }
}
