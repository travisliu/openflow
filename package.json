{
  "name": "@prmflow/openflow",
  "version": "0.2.0",
  "description": "Local-first workflow CLI for orchestrating coding-agent CLIs.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "OpenFlow contributors",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openflow": "dist/bin/openflow.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/travisliu/openflow.git"
  },
  "bugs": {
    "url": "https://github.com/travisliu/openflow/issues"
  },
  "homepage": "https://github.com/travisliu/openflow#readme",
  "keywords": [
    "workflow",
    "cli",
    "agent",
    "orchestration",
    "local-first"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "postbuild": "node scripts/fix-bin-permissions.mjs",
    "dev": "tsx src/bin/openflow.ts",
    "start": "node dist/bin/openflow.js",
    "typecheck": "npm run check",
    "check": "tsc --noEmit",
    "lint": "npm run check",
    "test": "vitest run --reporter=dot",
    "prepack": "npm run clean && npm run build",
    "pack:local": "npm pack",
    "publish:dry-run": "npm publish --dry-run",
    "release:check": "npm run typecheck && npm run lint && npm test && npm run build && npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "20",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "commander": "^15.0.0",
    "typescript": "^5.8.0",
    "yaml": "^2.9.0"
  }
}
